<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <!-- Заголовок -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📋 Планы на сегодня"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/widget_text"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_toStartOf="@id/widget_add_btn"
        android:layout_marginEnd="8dp" />

    <!-- Кнопка + — ImageView с цветным фоном через tint -->
    <ImageView
        android:id="@+id/widget_add_btn"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@android:drawable/ic_input_add"
        android:background="@drawable/widget_add_bg"
        android:padding="5dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:scaleType="centerInside" />

    <!-- Список планов — простой TextView, обновляется целиком -->
    <TextView
        android:id="@+id/widget_plans"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_title"
        android:layout_marginTop="10dp"
        android:textSize="13sp"
        android:textColor="@color/widget_subtext"
        android:lineSpacingExtra="5dp"
        android:gravity="top"
        android:text="Нет планов на сегодня" />

</RelativeLayout>
