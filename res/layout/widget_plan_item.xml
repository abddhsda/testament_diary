<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:background="@android:color/transparent">

    <!-- Эмодзи статуса: ○ или ✓ — тап = toggle -->
    <TextView
        android:id="@+id/widget_item_check"
        android:layout_width="22dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:gravity="center"
        android:text="○"
        android:textColor="@color/widget_subtext"
        android:padding="2dp" />

    <!-- Время (если есть) — перед текстом, серое -->
    <TextView
        android:id="@+id/widget_item_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/widget_subtext"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:visibility="gone" />

    <!-- Текст плана -->
    <TextView
        android:id="@+id/widget_item_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="13sp"
        android:textColor="@color/widget_text"
        android:maxLines="2"
        android:ellipsize="end" />

</LinearLayout>
